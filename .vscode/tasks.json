{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build rt1064 algorithm_main",
            "command": "gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}\\rt1064\\algorithm_main.c",
                "${workspaceFolder}\\rt1064\\sokoban_engine.c",
                "${workspaceFolder}\\rt1064\\sokoban_lut.c",
                "-o",
                "${workspaceFolder}\\rt1064\\algorithm_main.exe",
                "-lpsapi"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the PC simulation entry for rt1064/algorithm_main.c."
        }
    ]
}
